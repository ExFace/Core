    "modified_on": "2026-03-10 16:47:36",
    "contents": {
        "object_alias": "exface.Core.DOCS_FILES",
        "widget_type": "SplitHorizontal",
        "panels": [
            {
                "caption": "Apps",
                "width": "30%",
                "widgets": [
                    {
                        "widget_type": "DataTable",
                        "object_alias": "exface.Core.APP",
                        "id": "apps_table",
                        "filters": [
                            {
                                "attribute_alias": "LABEL"
                            }
                        ],
                        "columns": [
                            {
                                "attribute_alias": "NAME"
                            },
                            {
                                "attribute_alias": "ALIAS"
                            },
                            {
                                "attribute_alias": "PACKAGE",
                                "hidden": true
                            }
                        ],
                        "sorters": [
                            {
                                "attribute_alias": "ALIAS",
                                "direction": "asc"
                            }
                        ]
                    }
                ]
            },
            {
                "caption": "Documentation",
                "widgets": [
                    {
                        "object_alias": "exface.Core.DOCS_FILES",
                        "widget_type": "DataTree",
                        "tree_parent_relation_alias": "PARENT_FOLDER",
                        "tree_leaf_id_column": "=Base64(PATHNAME_RELATIVE, false, true)",
                        "tree_folder_flag_attribute_alias": "IS_FOLDER_FLAG",
                        "lazy_load_tree_levels": true,
                        "tree_expanded_levels": 2,
                        "autoload_disabled_hint": "Please select an app",
                        "filters": [
                            {
                                "attribute_alias": "APP",
                                "hidden": true,
                                "comparator": "==",
                                "value": "=apps_table!PACKAGE",
                                "apply_on_change": true,
                                "required": true
                            },
                            {
                                "attribute_alias": "NAME"
                            },
                            {
                                "attribute_alias": "PATH_RELATIVE"
                            }
                        ],
                        "columns": [
                            {
                                "attribute_alias": "NAME"
                            },
                            {
                                "attribute_alias": "EXTENSION"
                            },
                            {
                                "attribute_alias": "CREATED_ON"
                            },
                            {
                                "attribute_alias": "MODIFIED_ON"
                            },
                            {
                                "attribute_alias": "IS_FILE_FLAG",
                                "hidden": true
                            },
                            {
                                "attribute_alias": "PATH_RELATIVE",
                                "hidden": true
                            },
                            {
                                "attribute_alias": "PATHNAME_RELATIVE",
                                "hidden": true
                            }
                        ],
                        "buttons": [
                            {
                                "caption": "New document",
                                "refresh_input": true,
                                "action": {
                                    "alias": "exface.core.ShowObjectCreateDialog",
                                    "object_alias": "exface.Core.DOCS",
                                    "prefill_with_input_data": true,
                                    "input_mapper": {
                                        "from_object_alias": "exface.Core.DOCS_FILES",
                                        "to_object_alias": "exface.Core.DOCS",
                                        "inherit_columns": "none",
                                        "column_to_column_mappings": [
                                            {
                                                "from": "=If(IS_FILE_FLAG, PATH_RELATIVE, PATHNAME_RELATIVE)",
                                                "to": "PATH_RELATIVE"
                                            }
                                        ]
                                    }
                                }
                            },
                            {
                                "action_alias": "exface.Core.ShowObjectEditDialog",
                                "bind_to_double_click": true,
                                "disabled_if": {
                                    "operator": "AND",
                                    "conditions": [
                                        {
                                            "value_left": "=~input!EXTENSION",
                                            "comparator": "!==",
                                            "value_right": "md"
                                        }
                                    ]
                                }
                            },
                            {
                                "action_alias": "exface.Core.DeleteObject"
                            }
                        ]
                    }
                ]
            }
        ]
    }
}